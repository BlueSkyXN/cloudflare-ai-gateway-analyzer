# Cloudflare credentials (Cloudflare-native env names, recognised by the loader)
CF_API_TOKEN=
CF_EMAIL=
CF_API_KEY=

# Project-prefixed overrides use double underscores to delimit nested fields.
# Single-underscore variants (e.g. CF_AIGW_CONTROL_AUTH_TOKEN) are NOT picked
# up by pydantic-settings — they must be `CF_AIGW_<SECTION>__<FIELD>`.

# Optional bearer token gating the FastAPI control plane.
CF_AIGW_CONTROL__AUTH_TOKEN=

# Override the default ./local/data SQLite location.
CF_AIGW_STORAGE__DATA_DIR=

# Logging level (DEBUG / INFO / WARNING / ERROR)
CF_AIGW_LOGGING__LEVEL=INFO

# Override the control-plane bind. Loopback by default.
CF_AIGW_CONTROL__HOST=127.0.0.1
CF_AIGW_CONTROL__PORT=8765
